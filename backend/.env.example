# Environment variables for Rash Driving Detection System
# Copy this to .env and modify values as needed

# Flask secret key (change in production!)
SECRET_KEY=dev-secret-key-change-in-production

# Local setup (default)
SERVER_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Network Setup (optional, if using ngrok to expose backend)
# TUNNEL_URL=https://abc1234.ngrok.io

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///rash_driving.db

# Server settings
FLASK_ENV=development
FLASK_DEBUG=1

# API Key
API_KEY=default-secure-key-123

# Gemini API Key for AI Insights
GEMINI_API_KEY=your_gemini_api_key_here
