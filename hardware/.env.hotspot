# .env.hotspot — Copy to .env before running on phone hotspot
# Usage:  cp .env.hotspot .env
#
# ⚠️  You MUST verify the laptop's IP after connecting to the hotspot.
#     On the laptop run:  ipconfig
#     Then update SERVER_URL below with the correct IPv4 address.

SERVER_URL=http://10.36.125.<LAPTOP_OCTET>:5000
API_KEY=default-secure-key-123
BUS_REGISTRATION=KL-01-TEST-001
PHONE_GPS_PORT=8081
ENABLE_CAMERA=false
