# ─── OnboardRash Driver App ─────────────────────────────
# Copy this file to .env and fill in your backend server IP.
# Backend API URL (Flask server)
# Optional overrides for building:
# If you are testing with a real Pi/Phone decoupled from the laptop's network,
# set this to your ngrok tunnel URL.
# EXPO_PUBLIC_API_URL=https://abc1234.ngrok.io
#
# Otherwise, for local dev, leave it empty or comment it out and the app will auto-detect
# the Expo dev server IP.
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000
